# FunLearn - Environment Variables Template
# Powered by DigitalOcean Gradient AI
# Copy this file to .env and fill in your API keys

# ==============================================================================
# APPLICATION SETTINGS
# ==============================================================================
APP_NAME=FunLearn
APP_ENV=development
DEBUG=true
SECRET_KEY=change_this_to_a_random_secret_key_in_production

# ==============================================================================
# SERVER CONFIGURATION
# ==============================================================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173

# ==============================================================================
# PROVIDER SELECTION
# ==============================================================================
# Change these to switch between providers without changing code!
AI_PROVIDER=digitalocean    # Options: digitalocean, gemini, openai, anthropic
IMAGE_PROVIDER=none         # Options: none, fibo, stability (disabled for DO hackathon)
VOICE_TTS_PROVIDER=none     # Options: none, gcp, azure (disabled for DO hackathon)
VOICE_STT_PROVIDER=none     # Options: none, gcp, azure (disabled for DO hackathon)

# ==============================================================================
# DIGITALOCEAN GRADIENT AI (Primary AI Provider for Hackathon)
# ==============================================================================
# Get your Gradient API Key from: https://cloud.digitalocean.com/
GRADIENT_API_KEY=your_gradient_api_key_here
GRADIENT_BASE_URL=https://inference.do-ai.run/v1
GRADIENT_MODEL=meta-llama/Meta-Llama-3.3-70B-Instruct
RITTY_AGENT_UUID=your_ritty_agent_uuid_from_terraform_output

# ==============================================================================
# DATA STORAGE
# ==============================================================================
# For local development
DATA_DIR=./data
CSV_DIR=./data/csv
MEDIA_DIR=./data/media

# For deployment with DigitalOcean Volume
# DATA_DIR=/mnt/funlearn-data/csv
# CSV_DIR=/mnt/funlearn-data/csv
# MEDIA_DIR=/mnt/funlearn-data/media

# ==============================================================================
# JWT SETTINGS
# ==============================================================================
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ==============================================================================
# NOTES
# ==============================================================================
# - Never commit the .env file to version control
# - Keep API keys secure and rotate them periodically
# - For production, use proper secrets management
# - Generate a strong SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(32))"
# - RITTY_AGENT_UUID is obtained from Terraform output after creating the Gradient AI Agent
